# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# AVIATIONSTACK_API_KEY: Required for flight searches.
# Users configure this via the Secrets panel in the AI Studio UI.
AVIATIONSTACK_API_KEY=YOUR_AVIATIONSTACK_API_KEY

# AVIATIONSTACK_BASE_URL: Override if caching proxy or external server is used.
# Defaults to standard http endpoint to avoid free-tier https errors.
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/
